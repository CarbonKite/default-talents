{
  "id": "claude-code-onsite",
  "name": "Claude Code Engineer",
  "version": "1.0.0",
  "role": "Engineer",
  "hosting": "self",
  "settings": {
    "sections": [
      {
        "id": "connection",
        "title": "Connection",
        "fields": [
          {"key": "oauth", "type": "oauth_button", "label": "Anthropic Login", "provider": "anthropic"}
        ]
      },
      {
        "id": "session",
        "title": "Session",
        "fields": [
          {"key": "session_status", "type": "readonly", "label": "Status", "value_from": "api:sessions"}
        ]
      }
    ]
  },
  "prompts": {
    "skills": ["skills/*.md"]
  },
  "tools": {
    "builtin": ["sandbox_execute_code", "sandbox_run_command", "sandbox_write_file", "sandbox_read_file"],
    "custom": []
  },
  "platform_capabilities": ["file_upload", "websocket"],
  "heartbeat": {"method": "pid"}
}
